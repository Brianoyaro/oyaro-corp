# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
# For Gmail: Use App Password (not your main password)
# Generate here: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@nthuli-shop.com

# ========================================
# ADMIN BOOTSTRAP CONFIGURATION
# ========================================
# Initial admin user created on first application startup
# This email will be the admin account (if no admin exists)
# IMPORTANT: Change the default password immediately after first login!
ADMIN_EMAIL=admin@nthuli-shop.com
ADMIN_DEFAULT_PASSWORD=Admin@123456

# ========================================
# FRONTEND CONFIGURATION
# ========================================
# Frontend base URL for password reset links and redirects
# For development:
FRONTEND_BASE_URL=http://localhost:5173
# For production:
# FRONTEND_BASE_URL=https://yourdomain.com

paystack.base-url=https://api.paystack.co
